<Window x:Class="Gemini.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Gemini Desktop (Unofficial)" Height="880" Width="1300"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="Win11Btn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C4C7C5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3A3D45"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4A4D55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2D35"/>
            <Setter Property="Foreground" Value="#C4C7C5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3D45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3A3D45"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4A4D55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win11CloseBtn" TargetType="Button" BasedOn="{StaticResource Win11Btn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2B8B5"/>
                    <Setter Property="Foreground" Value="#601410"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E3928E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#B3131314" BorderBrush="#2E3035" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" x:Name="TitleBar" Background="#801E1F22" CornerRadius="7,7,0,0" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                        <Image x:Name="AppIcon" 
                               Width="24" 
                               Height="24" 
                               Margin="0,0,8,0" 
                               VerticalAlignment="Center"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"/>
                        <TextBlock Text="Gemini Desktop (Unofficial)" Foreground="#E3E3E3" FontSize="12.5" FontFamily="Segoe UI, Roboto" FontWeight="Medium" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource BackBtnStyle}" Content="◀ Revenir" Click="BtnBackToGemini_Click" ToolTip="Revenir à Gemini" />
                    </StackPanel>

                    <Grid Grid.Column="1" Background="Transparent" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Win11Btn}" Content="─" Click="BtnMinimize_Click" ToolTip="Réduire"/>
                        <Button Style="{StaticResource Win11Btn}" x:Name="btnMax" Content="❏" Click="BtnMaximize_Click" ToolTip="Agrandir / Rétablir"/>
                        <Button Style="{StaticResource Win11CloseBtn}" Content="✕" Click="BtnClose_Click" ToolTip="Fermer"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" CornerRadius="0,0,7,7" ClipToBounds="True">
                <wv2:WebView2 Name="webView" />
            </Border>
        </Grid>
    </Border>
</Window>
